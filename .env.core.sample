# .env sample cho Core Business (team-core)

MQTT_BROKER=broker.example.local
MQTT_PORT=1883
MQTT_USERNAME=IoT
MQTT_PASSWORD=lab05pass

CORE_MQTT_CLIENT_ID=team-core-client-01
CORE_SUBSCRIBE_TOPICS=smart-campus/events/sensor,smart-campus/events/access,smart-campus/events/camera
CORE_ALERT_TOPIC=smart-campus/events/alert

# REST endpoints (nếu cần gọi Access/AI)
ACCESS_GATE_URL=http://team-access:8000
AI_VISION_URL=http://team-vision:8000

# Persistence & audit
AUDIT_DB_PATH=./data/core_audit.db
LOG_LEVEL=info

# Alert deduplication window in seconds
ALERT_DEDUP_WINDOW=300
