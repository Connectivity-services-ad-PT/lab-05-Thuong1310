# .env sample cho IoT Ingestion (team-iot)
# Thay giá trị phù hợp cho môi trường của bạn; KHÔNG commit giá trị thật

MQTT_BROKER=broker.example.local
MQTT_PORT=1883
MQTT_USERNAME=IoT
MQTT_PASSWORD=lab05pass

IOT_MQTT_CLIENT_ID=team-iot-client-01
IOT_RAW_TOPIC=smart-campus/raw/iot/environment
IOT_EVENTS_TOPIC=smart-campus/events/sensor

# Đường dẫn file registry (relative to service root)
DEVICE_REGISTRY_PATH=./config/device_registry.csv

# Logging & behavior
LOG_LEVEL=info
PUBLISH_QOS=1
PUBLISH_RETAIN=false

# Processing tuning
NORMAL_PUBLISH_THROTTLE_SECONDS=5
